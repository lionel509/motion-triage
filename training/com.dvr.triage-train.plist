<?xml version="1.0" encoding="UTF-8"?>
<!-- Continuous behavior-NN training. Install on the deploy Mac:
     cp com.dvr.triage-train.plist ~/Library/LaunchAgents/
     launchctl load ~/Library/LaunchAgents/com.dvr.triage-train.plist
     Runs continuous_train.sh nightly at 03:30 (low-traffic window) and at load. -->
<plist version="1.0">
<dict>
  <key>Label</key><string>com.dvr.triage-train</string>
  <key>ProgramArguments</key>
  <array>
    <string>/bin/zsh</string>
    <string>/Users/andyweng/motion-triage/training/continuous_train.sh</string>
  </array>
  <key>StartCalendarInterval</key>
  <dict><key>Hour</key><integer>3</integer><key>Minute</key><integer>30</integer></dict>
  <key>RunAtLoad</key><false/>
  <key>StandardOutPath</key><string>/tmp/triage-train.launchd.log</string>
  <key>StandardErrorPath</key><string>/tmp/triage-train.launchd.log</string>
  <key>SoftResourceLimits</key><dict><key>NumberOfFiles</key><integer>10240</integer></dict>
</dict>
</plist>
